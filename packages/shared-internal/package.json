{
	"name": "agent-skill-harbor-shared-internal",
	"private": true,
	"version": "0.14.1",
	"type": "module",
	"license": "MIT",
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": ">=24"
	},
	"files": [
		"dist/"
	],
	"exports": {
		"./catalog-store": "./dist/src/catalog-store.js",
		"./resolved-from": "./dist/src/resolved-from.js"
	},
	"scripts": {
		"format": "prettier --write \"src/**/*.{js,ts,mjs,cjs,mts,cts}\" \"*.{json,md}\"",
		"format:check": "prettier --check \"src/**/*.{js,ts,mjs,cjs,mts,cts}\" \"*.{json,md}\"",
		"lint": "eslint --fix src",
		"lint:check": "eslint src",
		"check": "tsc --noEmit -p tsconfig.json",
		"build": "tsup",
		"test": "node -e \"console.log('No tests configured for agent-skill-harbor-shared-internal')\"",
		"verify": "pnpm run format:check && pnpm run lint:check && pnpm run check && pnpm run test"
	},
	"dependencies": {
		"js-yaml": "^4.1.0"
	},
	"devDependencies": {
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22.15.0",
		"eslint": "^9.18.0",
		"tsup": "8.5.1",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.20.0"
	}
}
